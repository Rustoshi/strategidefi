# Copy to .env and fill in. On Vercel, set these in Project Settings -> Environment Variables.

# MongoDB connection string (MongoDB Atlas recommended for Vercel).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/strategidefi?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWT auth tokens for the SPA /api/auth endpoints.
JWT_SECRET=change-me-to-a-long-random-string

# Session/cookie secret for the EJS admin panel.
ADMIN_SESSION_SECRET=change-me-too

# Bootstrap admin account created by `npm run seed`.
ADMIN_EMAIL=admin@strategidefi.com
ADMIN_PASSWORD=admin12345

# Public base URL where uploaded images are served from (used when seeding banners/coins).
# Leave as-is to reuse the already-working host, or point at your own storage / this app's /upload.
ASSET_BASE_URL=https://api.strategidefi.com

# Port for local dev (ignored on Vercel).
PORT=5173
