<%- include('partials/head') %>

<% if (flash) { %><div class="flash ok"><%= flash %></div><% } %>
<% if (err) { %><div class="flash err"><%= err %></div><% } %>

<div class="note">The amount already left the user's balance when they submitted. <b>Approve</b> confirms it; <b>Reject</b> refunds them automatically.</div>

<div class="bar">
  <a class="btn <%= status==='0'?'':'ghost' %> sm" href="/admin/withdrawals?status=0">Pending</a>
  <a class="btn <%= status==='1'?'':'ghost' %> sm" href="/admin/withdrawals?status=1">Approved</a>
  <a class="btn <%= status==='2'?'':'ghost' %> sm" href="/admin/withdrawals?status=2">Rejected</a>
  <a class="btn <%= status===''?'':'ghost' %> sm" href="/admin/withdrawals?status=">All</a>
  <span class="muted" style="margin-left:auto"><%= total %> record<%= total===1?'':'s' %></span>
</div>

<% if (!rows.length) { %>
  <div class="panel"><div class="empty"><div class="big">↑</div>Nothing here.</div></div>
<% } else { %>
  <div class="tw">
    <table>
      <thead><tr><th>Order</th><th>User</th><th>Channel</th><th>Amount</th><th>Address</th><th>When</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% rows.forEach(function(r){ %>
          <tr>
            <td class="mono"><%= r.order_no %></td>
            <td><a href="/admin/users/<%= r.user_id %>" style="color:var(--gold)"><%= emails[r.user_id] || ('#'+r.user_id) %></a></td>
            <td><%= r.coin_type || r.coin_name %></td>
            <td class="mono"><b><%= r.amount %></b> <%= r.coin_name %><% if (r.fee) { %><div class="muted" style="font-size:11px">fee <%= r.fee %></div><% } %></td>
            <td class="mono wrap-cell" style="max-width:220px;font-size:11.5px"><%= r.address %></td>
            <td class="muted"><%= new Date(r.createdAt).toISOString().replace('T',' ').slice(0,16) %></td>
            <td><span class="tag <%= r.status===1?'on':(r.status===2?'off':'warn') %>"><%= ['Pending','Approved','Rejected'][r.status] %></span></td>
            <td>
              <% if (r.status === 0) { %>
                <div class="actions">
                  <form class="inline" method="post" action="/admin/withdrawals/<%= r.id %>/approve"
                        data-confirm="Mark this withdrawal as paid out? Their balance was already debited.">
                    <button class="btn sm" type="submit">Approve</button>
                  </form>
                  <form class="inline" method="post" action="/admin/withdrawals/<%= r.id %>/reject"
                        data-confirm="Reject and refund <%= r.amount %> <%= r.coin_name %> to this user?">
                    <button class="btn ghost sm" type="submit">Reject &amp; refund</button>
                  </form>
                </div>
              <% } else { %><span class="muted"><%= r.remark || '—' %></span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (pages > 1) { %>
    <div class="pager">
      <% for (var p=1; p<=pages; p++) { %>
        <% if (p===page) { %><span class="cur"><%= p %></span><% } else { %><a href="/admin/withdrawals?status=<%= status %>&page=<%= p %>"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<%- include('partials/foot') %>
