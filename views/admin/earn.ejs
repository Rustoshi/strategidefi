<%- include('partials/head') %>

<% if (flash) { %><div class="flash ok"><%= flash %></div><% } %>
<% if (err) { %><div class="flash err"><%= err %></div><% } %>

<div class="note">Nothing accrues on a timer. A position's earnings only grow when you credit realised yield here — each credit moves the balance and writes a transaction.</div>

<!-- ---------- Positions ---------- -->
<div class="panel">
  <h2>Open positions <span class="sub">· last 50</span></h2>
  <% if (!positions.length) { %>
    <div class="empty"><div class="big">✦</div>No one has staked yet.</div>
  <% } else { %>
    <div class="tw">
      <table>
        <thead><tr><th>#</th><th>User</th><th>Plan</th><th>Amount</th><th>Earned</th><th>Status</th><th>Credit yield</th></tr></thead>
        <tbody>
          <% positions.forEach(function(p){ %>
            <tr>
              <td class="mono">#<%= p.id %></td>
              <td><a href="/admin/users/<%= p.user_id %>" style="color:var(--gold)"><%= emails[p.user_id] || ('#'+p.user_id) %></a></td>
              <td><%= p.names %> <span class="muted"><%= p.day_num %>d</span></td>
              <td class="mono"><%= p.amount.toLocaleString() %></td>
              <td class="mono pos"><%= p.profit %></td>
              <td><span class="tag <%= p.status===1?'off':(p.status_text==='Matured'?'warn':'on') %>"><%= p.status_text %></span></td>
              <td>
                <% if (p.status === 0) { %>
                  <form method="post" action="/admin/earn/positions/<%= p.id %>/yield" style="display:flex;gap:6px;align-items:center">
                    <input name="amount" type="number" step="0.01" min="0.01" required placeholder="USDT" style="width:110px" />
                    <input name="remark" placeholder="note (optional)" style="width:150px" />
                    <button class="btn sm" type="submit">Credit</button>
                  </form>
                  <% if (p.status_text === 'Matured') { %>
                    <form method="post" action="/admin/earn/positions/<%= p.id %>/redeem" data-confirm="Return the principal to the user?" style="margin-top:6px">
                      <button class="btn ghost sm" type="submit">Return principal</button>
                    </form>
                  <% } %>
                <% } else { %><span class="muted">—</span><% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- ---------- Plans ---------- -->
<div class="panel">
  <h2>Plan tiers</h2>
  <div class="tw">
    <table>
      <thead><tr><th>#</th><th>Name</th><th>Amount range</th><th>Daily rate</th><th>Cycle</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% plans.forEach(function(p){ %>
          <tr>
            <td class="mono">#<%= p.id %></td>
            <td><%= p.names %></td>
            <td class="mono"><%= p.min_price.toLocaleString() %> – <%= p.max_price.toLocaleString() %></td>
            <td class="mono"><%= (p.profit_rate_min*100).toFixed(2) %>% – <%= (p.profit_rate_max*100).toFixed(2) %>%</td>
            <td><%= p.day_num %> day</td>
            <td><span class="tag <%= p.status===1?'on':'off' %>"><%= p.status===1?'Active':'Hidden' %></span></td>
            <td>
              <form class="inline" method="post" action="/admin/earn/plans/<%= p.id %>/delete" data-confirm="Delete this tier?">
                <button class="btn danger sm" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!plans.length) { %><tr><td colspan="7" class="muted" style="text-align:center;padding:24px">No plans. Add one below, or run <code>node scripts/seed-staking.js</code>.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="panel">
  <h2>Add / edit a tier</h2>
  <form method="post" action="/admin/earn/plans">
    <div class="row3">
      <div><label>Tier ID (blank = new)</label><input name="id" placeholder="new" /></div>
      <div><label>Name</label><input name="names" value="Tether AI" required /></div>
      <div><label>Icon URL</label><input name="image" value="/tether.png" /></div>
    </div>
    <div class="row3">
      <div><label>Min amount</label><input name="min_price" type="number" step="0.01" required /></div>
      <div><label>Max amount</label><input name="max_price" type="number" step="0.01" required /></div>
      <div><label>Cycle (days)</label><input name="day_num" type="number" min="1" value="1" required /></div>
    </div>
    <div class="row3">
      <div><label>Daily rate min (%)</label><input name="profit_rate_min" type="number" step="0.01" placeholder="1.40" required /></div>
      <div><label>Daily rate max (%)</label><input name="profit_rate_max" type="number" step="0.01" placeholder="1.80" required /></div>
      <div><label>Sort</label><input name="sort" type="number" value="0" /></div>
    </div>
    <div class="row3">
      <div><label>Status</label><select name="status"><option value="1">Active</option><option value="0">Hidden</option></select></div>
    </div>
    <div style="margin-top:14px"><button class="btn" type="submit">Save tier</button></div>
  </form>
</div>

<%- include('partials/foot') %>
