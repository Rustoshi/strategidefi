<%- include('partials/head') %>

<div class="cards">
  <div class="card"><div class="n"><%= stats.users %></div><div class="l">Users</div></div>
  <div class="card"><div class="n"><%= stats.totalUsdt.toLocaleString() %></div><div class="l">Simulated USDT held</div></div>
  <div class="card"><div class="n"><%= stats.pendingDeposits %></div><div class="l">Deposits pending</div></div>
  <div class="card"><div class="n"><%= stats.pendingWithdrawals %></div><div class="l">Withdrawals pending</div></div>
  <div class="card"><div class="n"><%= stats.coins %></div><div class="l">Active coins</div></div>
</div>

<% if (stats.pendingDeposits || stats.pendingWithdrawals) { %>
  <div class="note">
    Awaiting review:
    <% if (stats.pendingDeposits) { %><a href="/admin/deposits"><%= stats.pendingDeposits %> deposit<%= stats.pendingDeposits===1?'':'s' %></a><% } %>
    <% if (stats.pendingDeposits && stats.pendingWithdrawals) { %> · <% } %>
    <% if (stats.pendingWithdrawals) { %><a href="/admin/withdrawals"><%= stats.pendingWithdrawals %> withdrawal<%= stats.pendingWithdrawals===1?'':'s' %></a><% } %>
  </div>
<% } %>

<div class="panel">
  <h2>Newest users <span class="sub">· <a href="/admin/users" style="color:var(--gold)">view all</a></span></h2>
  <% if (!recentUsers.length) { %>
    <div class="empty"><div class="big">◍</div>No users yet.</div>
  <% } else { %>
    <div class="tw">
      <table>
        <thead><tr><th>ID</th><th>Email</th><th>Wallet</th><th>Status</th><th>Joined</th><th></th></tr></thead>
        <tbody>
          <% recentUsers.forEach(function(u){ %>
            <tr>
              <td class="mono">#<%= u.id %></td>
              <td><%= u.email %></td>
              <td><% if (u.wallet_connected) { %><span class="tag on">Linked</span><% } else { %><span class="muted">—</span><% } %></td>
              <td><% if (u.status === 1) { %><span class="tag on">Active</span><% } else { %><span class="tag off">Disabled</span><% } %></td>
              <td class="muted"><%= new Date(u.createdAt).toISOString().slice(0,10) %></td>
              <td><a class="btn ghost sm" href="/admin/users/<%= u.id %>">Manage</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/foot') %>
