<%- include('partials/head') %>

<style>
  .thread{display:flex;flex-direction:column;gap:10px;max-height:58vh;overflow-y:auto;padding:4px 2px 8px}
  .msg{max-width:74%;padding:9px 12px;border-radius:12px;font-size:13.5px;line-height:1.5;word-break:break-word;white-space:pre-wrap}
  .msg .at{display:block;font-size:10.5px;margin-top:5px;opacity:.65}
  .from-user{align-self:flex-start;background:var(--panel2);border:1px solid var(--line);border-bottom-left-radius:4px}
  .from-admin{align-self:flex-end;background:var(--gold-dim);border:1px solid rgba(240,201,71,.3);color:#f7e6a8;border-bottom-right-radius:4px}
  .composer{display:flex;gap:9px;align-items:flex-end;margin-top:14px}
  .composer textarea{min-height:46px;max-height:150px}
  @media(max-width:640px){ .msg{max-width:88%} }
</style>

<div class="crumb"><a href="/admin/messages">← Messages</a> / <%= user.email %></div>
<% if (flash) { %><div class="flash ok"><%= flash %></div><% } %>
<% if (err) { %><div class="flash err"><%= err %></div><% } %>

<div class="panel">
  <h2>
    <%= user.email %>
    <span class="sub">· <a href="/admin/users/<%= user.id %>" style="color:var(--gold)">user #<%= user.id %></a></span>
  </h2>

  <% if (!messages.length) { %>
    <div class="empty"><div class="big">✉</div>No messages in this conversation yet — say hello.</div>
  <% } else { %>
    <div class="thread" id="thread">
      <% messages.forEach(function(m){ %>
        <div class="msg <%= m.sender === 'admin' ? 'from-admin' : 'from-user' %>"><%= m.body %><span class="at"><%= m.sender === 'admin' ? 'Support' : user.email %> · <%= new Date(m.created_at).toISOString().replace('T',' ').slice(0,16) %></span></div>
      <% }) %>
    </div>
  <% } %>

  <form class="composer" method="post" action="/admin/messages/<%= user.id %>/reply">
    <textarea name="body" placeholder="Write a reply…" required maxlength="2000" id="body"></textarea>
    <button class="btn" type="submit">Send</button>
  </form>
  <div class="muted" style="font-size:11.5px;margin-top:8px">The user sees this in the app's Service screen. Enter sends; Shift+Enter for a new line.</div>
</div>

<script>
  // Newest messages at the bottom — start scrolled there.
  var t = document.getElementById('thread');
  if (t) t.scrollTop = t.scrollHeight;
  var body = document.getElementById('body');
  body.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); body.form.requestSubmit(); }
  });
  body.focus();
</script>

<%- include('partials/foot') %>
