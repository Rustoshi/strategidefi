<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · StrategiDeFi Admin</title>
  <style>
    :root { --bg:#0e1420; --panel:#161f2e; --panel2:#1c2738; --line:#26334a; --txt:#e7ecf3; --muted:#8ea0b8; --gold:#f0c947; --green:#2ecc71; --red:#e74c3c; }
    * { box-sizing:border-box; }
    body { margin:0; font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif; background:var(--bg); color:var(--txt); }
    a { color:inherit; text-decoration:none; }
    .layout { display:flex; min-height:100vh; }
    .side { width:220px; background:var(--panel); border-right:1px solid var(--line); padding:18px 0; position:sticky; top:0; height:100vh; }
    .brand { font-weight:700; font-size:16px; padding:0 20px 16px; color:var(--gold); border-bottom:1px solid var(--line); margin-bottom:10px; }
    .nav a { display:block; padding:10px 20px; color:var(--muted); }
    .nav a:hover { background:var(--panel2); color:var(--txt); }
    .nav a.active { color:var(--gold); border-left:3px solid var(--gold); background:var(--panel2); }
    .main { flex:1; padding:24px 28px; max-width:100%; overflow-x:auto; }
    h1 { font-size:20px; margin:0 0 18px; }
    .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:24px; }
    .card { background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:16px; }
    .card .n { font-size:28px; font-weight:700; color:var(--gold); }
    .card .l { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.05em; }
    table { width:100%; border-collapse:collapse; background:var(--panel); border:1px solid var(--line); border-radius:10px; overflow:hidden; }
    th,td { padding:10px 12px; text-align:left; border-bottom:1px solid var(--line); vertical-align:top; }
    th { background:var(--panel2); color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
    tr:last-child td { border-bottom:none; }
    img.thumb { height:34px; border-radius:4px; border:1px solid var(--line); }
    form.inline { display:inline; }
    input,textarea,select { background:var(--bg); border:1px solid var(--line); color:var(--txt); border-radius:6px; padding:8px 10px; font:inherit; width:100%; }
    textarea { min-height:70px; resize:vertical; }
    label { display:block; font-size:12px; color:var(--muted); margin:8px 0 4px; }
    .btn { background:var(--gold); color:#1a1300; border:none; border-radius:6px; padding:8px 14px; font-weight:600; cursor:pointer; }
    .btn.ghost { background:transparent; color:var(--muted); border:1px solid var(--line); }
    .btn.danger { background:var(--red); color:#fff; }
    .btn.sm { padding:5px 10px; font-size:12px; }
    .row { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:10px; }
    .panel { background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:18px; margin-bottom:22px; }
    .panel h2 { margin:0 0 12px; font-size:15px; }
    .topbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; }
    .muted { color:var(--muted); }
    .tag { display:inline-block; padding:2px 8px; border-radius:20px; font-size:12px; }
    .tag.on { background:rgba(46,204,113,.15); color:var(--green); }
    .tag.off { background:rgba(231,76,60,.15); color:var(--red); }
  </style>
</head>
<body>
<div class="layout">
  <aside class="side">
    <div class="brand">StrategiDeFi</div>
    <nav class="nav">
      <a href="/admin" class="<%= active==='dashboard'?'active':'' %>">Dashboard</a>
      <a href="/admin/banners" class="<%= active==='banners'?'active':'' %>">Banners</a>
      <a href="/admin/coins" class="<%= active==='coins'?'active':'' %>">Coins</a>
      <a href="/admin/notices" class="<%= active==='notices'?'active':'' %>">Notices</a>
      <a href="/admin/settings" class="<%= active==='settings'?'active':'' %>">Settings</a>
      <a href="/admin/users" class="<%= active==='users'?'active':'' %>">Users</a>
      <a href="/" target="_blank">View site ↗</a>
      <form action="/admin/logout" method="post" style="padding:10px 20px;">
        <button class="btn ghost sm" type="submit">Log out</button>
      </form>
    </nav>
  </aside>
  <main class="main">
