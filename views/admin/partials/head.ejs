<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · StrategiDeFi Admin</title>
  <style>
    :root{
      --bg:#0B1017; --panel:#141B26; --panel2:#1B2430; --line:#26313F;
      --txt:#E7ECF3; --muted:#8B99AD; --gold:#F0C947; --gold-dim:rgba(240,201,71,.12);
      --green:#2ECC71; --red:#E74C3C; --blue:#4A9DFF;
      --radius:12px; --side:248px;
    }
    *{box-sizing:border-box}
    html,body{overflow-x:hidden}
    body{margin:0;font:14px/1.55 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;background:var(--bg);color:var(--txt);-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}

    /* ---------- shell ---------- */
    .side{
      position:fixed;inset:0 auto 0 0;width:var(--side);z-index:60;
      background:var(--panel);border-right:1px solid var(--line);
      display:flex;flex-direction:column;transform:translateX(-100%);
      transition:transform .22s ease;
    }
    .side.open{transform:none}
    .brand{display:flex;align-items:center;gap:9px;padding:16px 18px;border-bottom:1px solid var(--line);flex:0 0 auto}
    .brand .dot{width:26px;height:26px;border-radius:7px;background:var(--gold);color:#1a1300;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px}
    .brand b{font-size:14.5px;letter-spacing:.01em}
    .nav{flex:1;overflow-y:auto;padding:10px 10px 16px}
    .nav .grp{padding:14px 10px 6px;font-size:10.5px;letter-spacing:.09em;text-transform:uppercase;color:#5F6B7D;font-weight:700}
    .nav a{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;color:var(--muted);font-size:13.5px;min-height:38px}
    .nav a:hover{background:var(--panel2);color:var(--txt)}
    .nav a.active{background:var(--gold-dim);color:var(--gold);font-weight:600}
    .nav a .ic{width:17px;text-align:center;flex:0 0 auto;opacity:.9}
    .side .foot{flex:0 0 auto;border-top:1px solid var(--line);padding:12px}
    .side .who{font-size:12px;color:var(--muted);padding:0 4px 9px;word-break:break-all}

    .backdrop{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:55;opacity:0;pointer-events:none;transition:opacity .22s}
    .backdrop.on{opacity:1;pointer-events:auto}

    .wrap{min-height:100vh;display:flex;flex-direction:column}
    .topbar{
      position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:12px;
      padding:11px 16px;background:rgba(11,16,23,.9);backdrop-filter:blur(8px);
      border-bottom:1px solid var(--line);
    }
    .burger{width:38px;height:38px;border-radius:9px;border:1px solid var(--line);background:var(--panel);color:var(--txt);font-size:16px;cursor:pointer;flex:0 0 auto}
    .topbar h1{font-size:16px;margin:0;font-weight:600;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .main{padding:18px 16px 40px;flex:1}

    @media(min-width:1024px){
      .side{transform:none}
      .backdrop{display:none}
      .burger{display:none}
      .wrap{margin-left:var(--side)}
      .topbar{padding:14px 26px}
      .main{padding:24px 26px 56px}
    }

    /* ---------- components ---------- */
    .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px}
    .panel{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:18px;margin-bottom:18px}
    .panel h2{margin:0 0 14px;font-size:14.5px;font-weight:600;display:flex;align-items:center;gap:8px}
    .panel h2 .sub{font-weight:400;font-size:12px;color:var(--muted)}
    .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:20px}
    .card .n{font-size:24px;font-weight:700;color:var(--gold);line-height:1.2}
    .card .l{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-top:4px}

    /* tables never widen the page — they scroll inside their own box */
    .tw{overflow-x:auto;-webkit-overflow-scrolling:touch;border:1px solid var(--line);border-radius:var(--radius);background:var(--panel)}
    table{width:100%;border-collapse:collapse;min-width:560px}
    th,td{padding:11px 13px;text-align:left;border-bottom:1px solid var(--line);vertical-align:middle;white-space:nowrap}
    th{background:var(--panel2);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;font-weight:600}
    tr:last-child td{border-bottom:none}
    tbody tr:hover{background:rgba(255,255,255,.02)}
    td.wrap-cell{white-space:normal;min-width:200px}

    input,textarea,select{background:var(--bg);border:1px solid var(--line);color:var(--txt);border-radius:8px;padding:9px 11px;font:inherit;width:100%;min-height:40px}
    input:focus,textarea:focus,select:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(240,201,71,.12)}
    textarea{min-height:74px;resize:vertical}
    label{display:block;font-size:11.5px;color:var(--muted);margin:10px 0 5px;font-weight:500}
    .row{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px}
    .row3{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}

    .btn{background:var(--gold);color:#1a1300;border:none;border-radius:8px;padding:9px 15px;font-weight:600;cursor:pointer;font:inherit;font-weight:600;min-height:40px}
    .btn:hover{filter:brightness(1.07)}
    .btn.ghost{background:transparent;color:var(--muted);border:1px solid var(--line)}
    .btn.ghost:hover{color:var(--txt);border-color:#3A4757}
    .btn.danger{background:var(--red);color:#fff}
    .btn.sm{padding:6px 11px;font-size:12px;min-height:32px}
    .btn:disabled{opacity:.5;cursor:not-allowed}
    form.inline{display:inline}
    .actions{display:flex;gap:7px;flex-wrap:wrap}

    .tag{display:inline-block;padding:3px 9px;border-radius:20px;font-size:11.5px;font-weight:600;white-space:nowrap}
    .tag.on{background:rgba(46,204,113,.14);color:var(--green)}
    .tag.off{background:rgba(231,76,60,.14);color:var(--red)}
    .tag.warn{background:rgba(240,201,71,.14);color:var(--gold)}
    .tag.info{background:rgba(74,157,255,.14);color:var(--blue)}
    .muted{color:var(--muted)}
    .mono{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12.5px}
    .pos{color:var(--green)} .neg{color:var(--red)}

    .flash{padding:11px 14px;border-radius:10px;margin-bottom:16px;font-size:13px;border:1px solid}
    .flash.ok{background:rgba(46,204,113,.1);border-color:rgba(46,204,113,.3);color:#8ff0bb}
    .flash.err{background:rgba(231,76,60,.1);border-color:rgba(231,76,60,.3);color:#ffa79e}
    .note{background:rgba(240,201,71,.07);border:1px solid rgba(240,201,71,.25);color:#f3dc95;padding:11px 13px;border-radius:10px;font-size:12.5px;margin-bottom:14px;line-height:1.6}
    .empty{text-align:center;padding:36px 16px;color:var(--muted)}
    .empty .big{font-size:26px;margin-bottom:8px;opacity:.5}
    .bar{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:14px}
    .bar .grow{flex:1;min-width:180px}
    .pager{display:flex;gap:7px;justify-content:center;margin-top:16px;flex-wrap:wrap}
    .pager a,.pager span{padding:7px 12px;border-radius:8px;border:1px solid var(--line);font-size:13px;color:var(--muted)}
    .pager a:hover{color:var(--txt);border-color:#3A4757}
    .pager .cur{background:var(--gold-dim);color:var(--gold);border-color:transparent;font-weight:600}
    .crumb{font-size:12.5px;color:var(--muted);margin-bottom:12px}
    .crumb a{color:var(--gold)}
  </style>
</head>
<body>
<%
  // `admin` is set on res.locals by requireAdmin, so every authed page has it.
  var email = (typeof admin !== 'undefined' && admin) ? admin.email : '';
  var NAV = [
    { grp:'Overview', items:[ ['dashboard','/admin','▦','Dashboard'] ] },
    { grp:'Users',    items:[ ['users','/admin/users','◍','Users'], ['messages','/admin/messages','✉','Messages'] ] },
    { grp:'Money',    items:[
        ['deposits','/admin/deposits','↓','Deposits'],
        ['withdrawals','/admin/withdrawals','↑','Withdrawals'],
        ['transactions','/admin/transactions','≡','Transactions'] ] },
    { grp:'Products', items:[
        ['coins','/admin/coins','◈','Coins'],
        ['earn','/admin/earn','✦','Earn / Staking'] ] },
    { grp:'Content',  items:[
        ['banners','/admin/banners','▤','Banners'],
        ['notices','/admin/notices','!','Notices'] ] },
    { grp:'Settings', items:[
        ['set-deposit','/admin/settings/deposit','◎','Deposit wallets'],
        ['set-withdraw','/admin/settings/withdraw','◎','Withdrawals'],
        ['set-loan','/admin/settings/loan','◎','Loan'],
        ['set-support','/admin/settings/support','◎','Support'],
        ['set-upload','/admin/settings/upload','◎','Uploads'],
        ['settings','/admin/settings','⚙','Site settings'] ] },
  ];
%>
<aside class="side" id="side">
  <div class="brand"><span class="dot">S</span><b>StrategiDeFi</b></div>
  <nav class="nav">
    <% NAV.forEach(function(g){ %>
      <div class="grp"><%= g.grp %></div>
      <% g.items.forEach(function(it){ %>
        <a href="<%= it[1] %>" class="<%= active===it[0]?'active':'' %>"><span class="ic"><%= it[2] %></span><%= it[3] %></a>
      <% }) %>
    <% }) %>
    <div class="grp">Site</div>
    <a href="/" target="_blank"><span class="ic">↗</span>View site</a>
  </nav>
  <div class="foot">
    <% if (email) { %><div class="who"><%= email %></div><% } %>
    <form action="/admin/logout" method="post"><button class="btn ghost sm" type="submit" style="width:100%">Log out</button></form>
  </div>
</aside>
<div class="backdrop" id="backdrop"></div>

<div class="wrap">
  <header class="topbar">
    <button class="burger" id="burger" aria-label="Menu">☰</button>
    <h1><%= title %></h1>
  </header>
  <main class="main">
