<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · StrategiDeFi</title>
  <style>
    :root{ --bg:#0B1017; --panel:#141B26; --line:#26313F; --txt:#E7ECF3; --muted:#8B99AD; --gold:#F0C947; }
    *{box-sizing:border-box}
    body{
      margin:0;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;
      font:14px/1.55 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      background:radial-gradient(1000px 620px at 50% -12%, #1B2434 0%, #0B1017 62%);color:var(--txt);
    }
    .box{width:100%;max-width:380px}
    .brand{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:22px}
    .brand .dot{width:32px;height:32px;border-radius:9px;background:var(--gold);color:#1a1300;display:flex;align-items:center;justify-content:center;font-weight:800}
    .brand b{font-size:16px;letter-spacing:.01em}
    .card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:26px 22px;box-shadow:0 24px 60px -20px rgba(0,0,0,.65)}
    h1{font-size:17px;margin:0 0 4px;font-weight:600}
    .sub{color:var(--muted);font-size:12.5px;margin-bottom:16px}
    label{display:block;font-size:11.5px;color:var(--muted);margin:12px 0 5px;font-weight:500}
    input{width:100%;background:#0B1017;border:1px solid var(--line);color:var(--txt);border-radius:8px;padding:11px 12px;font:inherit;min-height:44px}
    input:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(240,201,71,.12)}
    .btn{width:100%;margin-top:20px;background:var(--gold);color:#1a1300;border:none;border-radius:8px;padding:12px;font:inherit;font-weight:700;cursor:pointer;min-height:46px}
    .btn:hover{filter:brightness(1.07)}
    .err{background:rgba(231,76,60,.1);border:1px solid rgba(231,76,60,.32);color:#ffa79e;padding:10px 12px;border-radius:9px;font-size:12.5px;margin-bottom:6px}
    .foot{text-align:center;margin-top:16px;font-size:12px;color:#5F6B7D}
    .foot a{color:var(--muted);text-decoration:none}
    .foot a:hover{color:var(--txt)}
  </style>
</head>
<body>
  <div class="box">
    <div class="brand"><span class="dot">S</span><b>StrategiDeFi</b></div>
    <div class="card">
      <h1>Admin sign in</h1>
      <div class="sub">Restricted area — administrator accounts only.</div>
      <% if (error) { %><div class="err"><%= error %></div><% } %>
      <form action="/admin/login" method="post">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" autocomplete="username" required autofocus />
        <label for="password">Password</label>
        <input id="password" type="password" name="password" autocomplete="current-password" required />
        <button class="btn" type="submit">Sign in</button>
      </form>
    </div>
    <div class="foot"><a href="/">← Back to site</a></div>
  </div>
</body>
</html>
