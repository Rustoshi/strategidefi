<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · StrategiDeFi</title>
  <style>
    body { margin:0; font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif; background:#0e1420; color:#e7ecf3; display:flex; min-height:100vh; align-items:center; justify-content:center; }
    .box { width:340px; background:#161f2e; border:1px solid #26334a; border-radius:12px; padding:28px; }
    .box h1 { margin:0 0 4px; font-size:20px; color:#f0c947; }
    .box p { margin:0 0 20px; color:#8ea0b8; font-size:13px; }
    label { display:block; font-size:12px; color:#8ea0b8; margin:12px 0 4px; }
    input { width:100%; background:#0e1420; border:1px solid #26334a; color:#e7ecf3; border-radius:6px; padding:10px; font:inherit; }
    .btn { width:100%; margin-top:18px; background:#f0c947; color:#1a1300; border:none; border-radius:6px; padding:11px; font-weight:600; cursor:pointer; }
    .err { background:rgba(231,76,60,.15); color:#e74c3c; padding:9px 12px; border-radius:6px; font-size:13px; margin-bottom:8px; }
  </style>
</head>
<body>
  <form class="box" action="/admin/login" method="post">
    <h1>StrategiDeFi</h1>
    <p>Admin panel</p>
    <% if (error) { %><div class="err"><%= error %></div><% } %>
    <label>Email</label>
    <input type="email" name="email" required autofocus />
    <label>Password</label>
    <input type="password" name="password" required />
    <button class="btn" type="submit">Sign in</button>
  </form>
</body>
</html>
