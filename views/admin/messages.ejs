<%- include('partials/head') %>

<div class="bar">
  <a class="btn <%= onlyUnread?'ghost':'' %> sm" href="/admin/messages">All conversations</a>
  <a class="btn <%= onlyUnread?'':'ghost' %> sm" href="/admin/messages?unread=1">
    Unread<% if (unreadTotal) { %> (<%= unreadTotal %>)<% } %>
  </a>
  <span class="muted" style="margin-left:auto"><%= total %> conversation<%= total===1?'':'s' %></span>
</div>

<% if (!rows.length) { %>
  <div class="panel">
    <div class="empty">
      <div class="big">✉</div>
      <%= onlyUnread ? 'Nothing unread — you are all caught up.' : 'No messages yet. They appear here when a user writes in from the Service screen.' %>
    </div>
  </div>
<% } else { %>
  <div class="tw">
    <table>
      <thead><tr><th>User</th><th>Last message</th><th>When</th><th>Messages</th><th></th></tr></thead>
      <tbody>
        <% rows.forEach(function(r){ %>
          <tr>
            <td>
              <a href="/admin/messages/<%= r.user_id %>" style="color:var(--gold)"><%= r.email %></a>
              <% if (r.unread) { %> <span class="tag warn"><%= r.unread %> new</span><% } %>
            </td>
            <td class="wrap-cell" style="max-width:420px">
              <span class="muted" style="font-size:11.5px"><%= r.last_sender === 'admin' ? 'You:' : '' %></span>
              <%= r.last_body.length > 90 ? r.last_body.slice(0,90) + '…' : r.last_body %>
            </td>
            <td class="muted"><%= new Date(r.last_at).toISOString().replace('T',' ').slice(0,16) %></td>
            <td class="mono"><%= r.total %></td>
            <td><a class="btn <%= r.unread ? '' : 'ghost' %> sm" href="/admin/messages/<%= r.user_id %>">Open chat</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (pages > 1) { %>
    <div class="pager">
      <% for (var p=1; p<=pages; p++) { %>
        <% if (p===page) { %><span class="cur"><%= p %></span>
        <% } else { %><a href="/admin/messages?page=<%= p %><%= onlyUnread?'&unread=1':'' %>"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<%- include('partials/foot') %>
