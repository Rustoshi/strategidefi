<%- include('partials/head') %>

<% if (flash) { %><div class="flash ok"><%= flash %></div><% } %>
<% if (err) { %><div class="flash err"><%= err %></div><% } %>

<div class="note">Deposits are never credited automatically. Approving one here is what actually credits the user's balance — check the payment voucher first.</div>

<div class="bar">
  <a class="btn <%= status==='0'?'':'ghost' %> sm" href="/admin/deposits?status=0">Pending</a>
  <a class="btn <%= status==='1'?'':'ghost' %> sm" href="/admin/deposits?status=1">Approved</a>
  <a class="btn <%= status==='2'?'':'ghost' %> sm" href="/admin/deposits?status=2">Rejected</a>
  <a class="btn <%= status===''?'':'ghost' %> sm" href="/admin/deposits?status=">All</a>
  <span class="muted" style="margin-left:auto"><%= total %> record<%= total===1?'':'s' %></span>
</div>

<% if (!rows.length) { %>
  <div class="panel"><div class="empty"><div class="big">↓</div>Nothing here.</div></div>
<% } else { %>
  <div class="tw">
    <table>
      <thead><tr><th>Order</th><th>User</th><th>Channel</th><th>Amount</th><th>Voucher</th><th>When</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% rows.forEach(function(r){ %>
          <tr>
            <td class="mono"><%= r.order_no %></td>
            <td><a href="/admin/users/<%= r.user_id %>" style="color:var(--gold)"><%= emails[r.user_id] || ('#'+r.user_id) %></a></td>
            <td><%= r.channel || r.coin_name %><div class="muted" style="font-size:11px"><%= r.method %></div></td>
            <td class="mono"><b><%= r.amount %></b> <%= r.coin_name %></td>
            <td>
              <% if (r.voucher) { %><a href="<%= r.voucher %>" target="_blank" rel="noopener"><img src="<%= r.voucher %>" alt="voucher" style="height:38px;border-radius:5px;border:1px solid var(--line)" /></a>
              <% } else { %><span class="muted">—</span><% } %>
            </td>
            <td class="muted"><%= new Date(r.createdAt).toISOString().replace('T',' ').slice(0,16) %></td>
            <td><span class="tag <%= r.status===1?'on':(r.status===2?'off':'warn') %>"><%= ['Pending','Approved','Rejected'][r.status] %></span></td>
            <td>
              <% if (r.status === 0) { %>
                <div class="actions">
                  <form class="inline" method="post" action="/admin/deposits/<%= r.id %>/approve"
                        data-confirm="Credit <%= r.amount %> <%= r.coin_name %> to this user?">
                    <button class="btn sm" type="submit">Approve</button>
                  </form>
                  <form class="inline" method="post" action="/admin/deposits/<%= r.id %>/reject" data-confirm="Reject this deposit?">
                    <button class="btn ghost sm" type="submit">Reject</button>
                  </form>
                </div>
              <% } else { %><span class="muted">—</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (pages > 1) { %>
    <div class="pager">
      <% for (var p=1; p<=pages; p++) { %>
        <% if (p===page) { %><span class="cur"><%= p %></span><% } else { %><a href="/admin/deposits?status=<%= status %>&page=<%= p %>"><%= p %></a><% } %>
      <% } %>
    </div>
  <% } %>
<% } %>

<%- include('partials/foot') %>
